{
  "name": "uni-place-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.13.5",
    "http-proxy-middleware": "2.0.9",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "react-scripts": "5.0.1",
    "recoil": "^0.7.7",
    "redux": "^5.0.1",
    "styled-components": "^6.3.11",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "check:source-tree": "node -e \"const fs=require('fs');const bad=['src/src','src/src.zip','src2222222222222','src.zip'].filter((p)=>fs.existsSync(p));if(bad.length){console.error('[source-tree-check] Duplicate source tree detected:\\n'+bad.map((p)=>'- '+p).join('\\n'));process.exit(1)}console.log('[source-tree-check] OK');\"",
    "prestart": "npm run check:source-tree",
    "start": "react-scripts start",
    "prebuild": "npm run check:source-tree",
    "build": "react-scripts build",
    "pretest": "npm run check:source-tree",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.3.0",
    "prettier": "^3.8.1"
  },
  "volta": {
    "node": "18.20.4"
  }
}
