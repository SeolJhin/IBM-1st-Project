# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=local

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LLM_PROVIDER=openai

# IBM watsonx.ai
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# Milvus / Zilliz Cloud
MILVUS_URI=
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION=uniplace_knowledge

# Embedding
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
WATSONX_EMBEDDING_MODEL_ID=

# Retrieval
TOP_K=5
SIMILARITY_THRESHOLD=0.2
RAG_SOURCE_DIR=data/rag
RAG_MANIFEST_PATH=runtime/rag/index_manifest.json
RAG_AUTO_REINDEX_ENABLED=true
RAG_REINDEX_INTERVAL_SECONDS=300
RAG_CHUNK_SIZE=1200
RAG_REINDEX_STRATEGY=incremental

# Voice runtime paths
VOICE_INPUT_DIR=runtime/voice/in
VOICE_OUTPUT_DIR=runtime/voice/out

# Document runtime paths
DOCUMENT_OUTPUT_DIR=runtime/documents

# Moderation / action sink
MODERATION_TERMS_PATH=data/policy/moderation_terms.json
ACTION_WEBHOOK_URL=
ACTION_WEBHOOK_TIMEOUT_SECONDS=3

# Admin / legacy controls
AI_ADMIN_API_KEY=
LEGACY_EXECUTE_ENABLED=false
