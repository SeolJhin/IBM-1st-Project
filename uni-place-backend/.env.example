DB_PASSWORD=student123

# must be 32+ chars
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_32CHARS_PLUS
JWT_ACCESS_EXP=86400000
JWT_REFRESH_EXP=86400000

APP_UPLOAD_DIR=C:/upload_files
